{
    "basic": {
        "description": "MoleculeACE + MolMCL GNN: MolMCL hyperparameters come from model.molmcl.external_config (yaml).",
        "log_dir_base": "/mnt/d/wsl-data/chemvl/results/moleculeace",
        "gpu": "0",
        "ngpu": 1,
        "num_workers": 0,
        "verbose": true,
        "prefix": "",
