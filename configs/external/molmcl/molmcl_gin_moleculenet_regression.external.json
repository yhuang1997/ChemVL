        "num_tasks": 1,
        "split": "scaffold",
        "chirality": true
    },
    "training": {
        "finetune_strategy": "fully_tuning",
        "eval_metric": "rmse",
        "seed": 1,
        "start_epoch": 0,
        "weighted_CE": false
