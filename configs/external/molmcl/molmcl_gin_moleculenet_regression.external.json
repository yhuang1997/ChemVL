{
    "basic": {
        "description": "MoleculeNet regression + MolMCL GIN (yaml per task via {dataset}_gin).",
        "log_dir_base": "/mnt/d/wsl-data/chemvl/results/baseline_methods",
        "gpu": "0",
        "ngpu": 1,
        "num_workers": 0,
        "verbose": true,
        "prefix": "",
        "save_finetune_ckpt": false,
        "version": "molmcl_gin_moleculenet"
    },
    "dataset": {
        "benchmark": "moleculenet",
