    "regression_scheduler": {
        "labels_csv_path": null
    },
    "model": {
        "finetune_backend": "molmcl_moleculenet",
        "molmcl": {
            "molmcl_root": "external/MolMCL",
            "external_config": "configs/external/molmcl/base_config/moleculenet/{dataset}_gin.yaml",
            "molmcl_overrides": {}
        }
    },
    "data_augmentation": {
        "multi_view": false
    }
