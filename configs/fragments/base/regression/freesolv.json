{
    "basic": {
        "version": "base",
        "log_dir_base": "results/",
        "gpu": "0",
        "ngpu": 1,
        "num_workers": 6,
        "verbose": true,
        "prefix": "",
        "save_finetune_ckpt": true,
        "description": "Base Finetuning on FreeSolv dataset"
    },
    "dataset": {
        "dataset": "freesolv",
        "dataroot": "datasets/downstream/MPP/regression",
        "task_type": "regression",
        "num_tasks": 1,
        "class_names": [
            "class1",
            "class2"
        ],
        "chirality": true,
        "context_initialization": ""
    },
    "regression_scheduler": {
        "num_classes": 100,
        "bin_mode": "quantile"
    },
    "model": {
        "vision_architecture": "RN50",
        "text_architecture": "RN50",
        "fusion_architecture": "RN50",
        "resume": "cache/checkpoints/pretraining/RN50px224.ckpt",
        "imageSize": 224,
        "logit_scale": 4.605,
        "prompt_learner": "coop",
        "prior_version": "all",
        "attention_mode": "attention",
        "attention_temperature": 100.0,
        "dropout": 0.2,
        "reduction_ratio": 4,
        "context_initialization": null
    },
    "training": {
        "finetune_strategy": "linear_probing",
        "seed": 1,
        "epochs": 50,
        "start_epoch": 0,
        "patience": 30,
        "batch_size": 128,
        "optimizer": "Adam",
        "scheduler": null,
        "lr": 0.001,
        "weight_decay": 0.001,
        "momentum": 0.9,
        "weighted_CE": false,
        "prior_lr_factor": 1.0,
        "max_grad_norm": null
    },
    "data_augmentation": {
        "image_aug": false,
        "Resize": 256,
        "CenterCrop": 224,
        "Normalize_mean": [
            0.485,
            0.456,
            0.406
        ],
        "Normalize_std": [
            0.229,
            0.224,
            0.225
        ]
    }
}
