{
    "basic": {
        "version": "ft_descriptor_only_text_all",
        "description": "Descriptor-only @text: prior sentences (PriorKnowledgeLib all) + CLIP text encoder + mean pool + MLP. Text embedding cache under CHEMVL_DATA_ROOT/cache_for_descriptor-only_knowledge/."
    },
    "dataset": {
        "dataroot": "/mnt/d/wsl-data/chemvl/finetuning_datasets/MPP/classification",
        "split": "scaffold",
        "task_type": "classification",
        "chirality": true,
        "context_initialization": "",
        "representation": "image",
        "depiction": {
            "render_canvas_px": 224,
            "render_preset": "default"
        },
        "descriptor_only_mode": "text",
        "prior_descriptor_version": "all"
    },
    "model": {
        "vision_architecture": "RN50",
        "text_architecture": "RN50",
        "fusion_architecture": "RN50",
        "imageSize": 224,
        "logit_scale": 4.605,
        "prompt_learner": "coop",
        "prior_version": "all",
        "attention_mode": "attention",
        "attention_temperature": 100.0,
        "context_initialization": "",
        "resume": "/mnt/d/wsl-data/chemvl/checkpoints/pretraining/RN50px224.ckpt",
        "descriptor_only": {
            "hidden_dims": [512, 256],
            "dropout": 0.1,
            "freeze_clip_text": true,
            "cache_text_embeddings": true
        }
    }
}
