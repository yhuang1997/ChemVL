{
    "basic": {
        "version": "kgpt_misplacement_mask_image_chemvl_misplacement",
        "description": "ChemVL image KGPT: train-only circular-shift misplacement (k auto from seed+runseed+dataset)."
    },
    "dataset": {
        "dataroot": "/mnt/d/wsl-data/chemvl/finetuning_datasets/MPP/classification",
        "split": "scaffold",
        "task_type": "classification",
        "chirality": true,
        "context_initialization": "",
        "representation": "image",
        "depiction": {
            "render_canvas_px": 224,
            "render_preset": "default"
        },
        "chemvl_ablation": {
            "misplacement": {
                "enabled": true,
                "split": "train",
                "mode": "circular_shift",
                "k": null
            }
        }
    },
    "model": {
        "vision_architecture": "RN50",
        "text_architecture": "RN50",
        "fusion_architecture": "RN50",
        "imageSize": 224,
        "logit_scale": 4.605,
        "prompt_learner": "coop",
        "prior_version": "all",
        "attention_mode": "attention",
        "attention_temperature": 100.0,
        "context_initialization": "",
        "resume": "/mnt/d/wsl-data/chemvl/checkpoints/pretraining/RN50px224.ckpt"
    }
}
